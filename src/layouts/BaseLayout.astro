---
import "../styles/global.css";
import "../styles/print.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import CookieConsent from "../components/CookieConsent.astro";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  customPrint?: boolean;
}

const { title, description = "Otevřená knowledge base a receptury na točenou zmrzlinu", ogImage, customPrint = false } = Astro.props;
const fullTitle = title === "Zmrzlina Na Samotách" ? title : `${title} — Zmrzlina Na Samotách`;
const canonical = new URL(Astro.url.pathname, Astro.site).toString();
---

<!doctype html>
<html lang="cs">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    <link rel="icon" type="image/png" href="/ranc-na-samotach-logo.png" />
    <link rel="apple-touch-icon" href="/ranc-na-samotach-logo.png" />
    <link
      rel="preconnect"
      href="https://fonts.googleapis.com"
    />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Sriracha&family=Rubik:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <script is:inline>
      // Anti-flicker: nastav uložené téma před vykreslením
      (function () {
        try {
          const t = localStorage.getItem("theme");
          if (t === "dark" || t === "light") {
            document.documentElement.setAttribute("data-theme", t);
          }
        } catch (e) {}
      })();
    </script>
  </head>
  <body class={customPrint ? "has-custom-print" : ""}>
    <div class="screen-only">
      <Header />
      <main>
        <div class="container">
          <slot />
        </div>
      </main>
      <Footer />
      <div class="print-footer">
        Zmrzlina Na Samotách · zmrzlina.nasamotach.cz · Recepty pod licencí CC BY-SA 4.0
      </div>
      <CookieConsent />
    </div>
    {customPrint && (
      <div class="print-only">
        <slot name="print" />
      </div>
    )}
  </body>
</html>
