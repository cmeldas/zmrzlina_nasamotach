---
import BaseLayout from "../../layouts/BaseLayout.astro";
import TagList from "../../components/TagList.astro";
import PrintRecipe from "../../components/PrintRecipe.astro";
import StavBadge from "../../components/StavBadge.astro";
import { getCollection, render } from "astro:content";
import { TYP_LABEL, OBTIZNOST_LABEL, STAV_LABEL, STAV_POPIS, filterPublished } from "../../lib/utils";

export async function getStaticPaths() {
  const recepty = filterPublished(await getCollection("recepty"));
  return recepty.map((r) => ({ params: { slug: r.id }, props: { recipe: r } }));
}

const { recipe } = Astro.props;
const { Content } = await render(recipe);
---

<BaseLayout title={recipe.data.title} description={recipe.data.description} customPrint={true}>
  <article>
    <div class="recipe-header-top no-print">
      <StavBadge stav={recipe.data.stav} showPopis={true} />
      {recipe.data.publikovat === false && (
        <span class="unpub-tag" title="Recept je viditelný jen v dev módu, ne na produkčním webu">
          DEV ONLY · nepublikováno
        </span>
      )}
    </div>
    <h1>{recipe.data.title}</h1>
    {recipe.data.description && <p style="font-size:1.05rem;color:var(--muted)">{recipe.data.description}</p>}

    {recipe.data.stav !== "odladeny" && (
      <div class={`stav-banner stav-banner-${recipe.data.stav} no-print`}>
        <strong>{STAV_LABEL[recipe.data.stav]}:</strong> {STAV_POPIS[recipe.data.stav]}
        {recipe.data.stav === "navrh" && " Než budeš vyrábět, doporučujeme menší zkušební várku."}
      </div>
    )}

    <dl class="recipe-meta">
      <div><dt>Typ</dt><dd>{TYP_LABEL[recipe.data.typ] ?? recipe.data.typ}</dd></div>
      {recipe.data.tuk_pct !== undefined && <div><dt>Tuk</dt><dd>{recipe.data.tuk_pct} %</dd></div>}
      {recipe.data.pac !== undefined && <div><dt>PAC</dt><dd>{recipe.data.pac}</dd></div>}
      {recipe.data.serv_teplota && <div><dt>Servírování</dt><dd>{recipe.data.serv_teplota}</dd></div>}
      {recipe.data.varka_kg && <div><dt>Várka</dt><dd>{recipe.data.varka_kg} kg</dd></div>}
      <div><dt>Obtížnost</dt><dd>{OBTIZNOST_LABEL[recipe.data.obtiznost] ?? recipe.data.obtiznost}</dd></div>
    </dl>

    <TagList tags={recipe.data.tags} />

    {recipe.data.pdf && (
      <div class="actions no-print">
        <a class="btn" href={recipe.data.pdf} download>
          ⬇ Stáhnout jako A4 PDF
        </a>
      </div>
    )}

    <Content />

    <section class="no-print" style="margin-top:2rem;font-size:0.9rem;color:var(--muted);border-top:1px dashed var(--line);padding-top:1rem">
      <strong>Licence:</strong> {recipe.data.licence}
      &nbsp;·&nbsp;
      <strong>Autor:</strong> {recipe.data.autor}
      &nbsp;·&nbsp;
      <a href="/licence/">Co to znamená?</a>
    </section>
  </article>

  <PrintRecipe
    slot="print"
    num={recipe.data.cislo ?? 0}
    title={recipe.data.title}
    typ={recipe.data.typ}
    tuk_pct={recipe.data.tuk_pct}
    pac={recipe.data.pac}
    serv_teplota={recipe.data.serv_teplota}
    varka_kg={recipe.data.varka_kg}
    autor={recipe.data.autor}
    stav={recipe.data.stav}
  >
    <Content />
  </PrintRecipe>
</BaseLayout>

<style>
  .recipe-header-top {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 0.5rem;
  }
  .stav-banner {
    margin: 1rem 0 1.5rem;
    padding: 0.75rem 1rem;
    border-radius: 8px;
    border-left: 4px solid;
    font-size: 0.95rem;
    line-height: 1.4;
  }
  .stav-banner-navrh {
    background: #fef3e8;
    border-left-color: #f0a040;
    color: #6b3a05;
  }
  .stav-banner-testovany {
    background: #fff7d6;
    border-left-color: #e8c34a;
    color: #5a4005;
  }
  .unpub-tag {
    display: inline-block;
    padding: 0.15em 0.6em;
    background: #fde2e2;
    border: 1px solid #d97777;
    border-radius: 4px;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.5pt;
    color: #8b1a1a;
  }
</style>
