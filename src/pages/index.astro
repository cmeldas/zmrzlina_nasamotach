---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { filterPublished } from "../lib/utils";
import Carousel from "../components/Carousel.astro";
import { resolveFotky, shuffle } from "../lib/fotky";

const recepty = filterPublished(await getCollection("recepty")).sort(
  (a, b) => (a.data.cislo ?? 999) - (b.data.cislo ?? 999)
);
const knowledgeCount = (await getCollection("knowledge")).length;
const ingredienceCount = (await getCollection("ingredience")).length;

// Všechny fotky ze všech publikovaných receptů, v náhodném pořadí.
// Pokud stejná fotka patří k více receptům, odkazy se vypíšou za sebou.
const fotkaToRecipes = new Map<string, { foto: ReturnType<typeof resolveFotky>[number]; recipes: { title: string; href: string }[] }>();
for (const r of recepty) {
  for (const foto of resolveFotky(r.data.fotky)) {
    const entry = fotkaToRecipes.get(foto.filename);
    const recipe = { title: r.data.title, href: `/recepty/${r.id}/` };
    if (entry) {
      entry.recipes.push(recipe);
    } else {
      fotkaToRecipes.set(foto.filename, { foto, recipes: [recipe] });
    }
  }
}
const vsechnyFotky = shuffle(
  [...fotkaToRecipes.values()].map(({ foto, recipes }) => ({ ...foto, recipes }))
);
---

<BaseLayout title="Zmrzlina Na Samotách" description="Otevřená knowledge base a receptury na točenou zmrzlinu — sdílíme vše, co jsme se naučili.">
  <section class="hero">
    <h1>Zmrzlina Na Samotách</h1>
    <p class="lead">
      Otevřená knowledge base a receptury na točenou zmrzlinu.
      Fyzikální chemie, postupy a recepty, které jsme si museli posbírat sami — a teď je sdílíme s tebou.
    </p>
    <div class="actions" style="justify-content:center">
      <a class="btn" href="/recepty/">Recepty ({recepty.length})</a>
      <a class="btn secondary" href="/knowledge/">Knowledge ({knowledgeCount})</a>
      <a class="btn secondary" href="/ingredience/">Ingredience ({ingredienceCount})</a>
    </div>
  </section>

  <section class="about-ranch" id="o-nas">
    <div class="about-ranch-logo">
      <img src="/ranc-na-samotach-logo.png" alt="Logo Ranč Na Samotách" width="260" height="224" loading="lazy" />
    </div>
    <div class="about-ranch-content">
      <h2>O nás</h2>
      <p>
        Jsme rodinný Ranč Na Samotách v jižních Čechách. Staráme se o statek,
        zvířata, vlastní mlékárnu a malý obchůdek, kde se všechno točí kolem
        poctivých surovin a normálního života na venkově.
      </p>
      <p>
        Zmrzlina je pro nás další způsob, jak z dobrého mléka a tvarohu udělat
        něco radostného. Tady sdílíme recepty, poznámky i slepé uličky, které
        nám cestou pomohly.
      </p>
      <div class="actions">
        <a class="btn" href="https://nasamotach.cz/" target="_blank" rel="noopener">Web ranče</a>
        <a class="btn secondary" href="https://www.facebook.com/nasamotach" target="_blank" rel="noopener">Facebook</a>
      </div>
    </div>
  </section>

  {vsechnyFotky.length > 0 && (
    <section>
      <h2>Z naší výroby</h2>
      <Carousel fotky={vsechnyFotky} />
    </section>
  )}

  <section>
    <h2>Proč tenhle web vznikl</h2>
    <p>
      Když jsme začínali s točenou zmrzlinou, sami jsme bojovali s nedostatkem
      použitelných informací. Přitom udělat jednoduchou a dobrou točenou zmrzlinu není raketová věda. 
    </p>
    <p>
      Zde přístupná knowledge base je vytvořená pomocí AI researche. Vše je ozdrojované a kdykoli můžete více do hloubky zabrouzdat. Nám toto na začátku chybělo a díky AI máme mnohem lepší obraz a problematice.
    </p>
        <p>
      Samozřejmě, že by bylo nejlepší projezdit Itálii a nasbírat zkušenosti osobně. Nebo si zaplatit mnoho kurzů. Na tuto cestu nemáme čas ani peníze.
    </p>
    <p>
      Web je <a href="/licence/">otevřený</a> a každý může přispět svým receptem
      přes <a href="/prispivat/">pull request na GitHubu</a>.
    </p>
  </section>

  <section>
    <h2>Začni tady</h2>
    <div class="cards">
      <div class="card">
        <h3><a href="/knowledge/cukry-ve-zmrzline/" class="titlelink">1 · Cukry a PAC</a></h3>
        <p class="desc">PAC, FPDF, jak vybrat poměr sacharóza/dextróza/glukóza. Nejdůležitější pojem v celé zmrzlinařině.</p>
      </div>
      <div class="card">
        <h3><a href="/knowledge/tuky-ve-zmrzline/" class="titlelink">2 · Tuky a struktura</a></h3>
        <p class="desc">Mléčný tuk, částečná koalescence, MFGM — srdce krémové textury.</p>
      </div>
      <div class="card">
        <h3><a href="/knowledge/procesni-parametry/" class="titlelink">3 · Procesy</a></h3>
        <p class="desc">Pasterizace, homogenizace, aging, freezing, hardening — co se kdy a proč dělá.</p>
      </div>
      <div class="card">
        <h3><a href="/recepty/smetanovy-zaklad/" class="titlelink">4 · Univerzální základ</a></h3>
        <p class="desc">Smetanový základ, ze kterého se dá postavit vanilka, čokoláda, ořech i ovoce.</p>
      </div>
    </div>
  </section>

  <section>
    <h2>Recepty ({recepty.length})</h2>
    <div class="cards">
      {recepty.map((r) => (
        <div class="card">
          <h3><a href={`/recepty/${r.id}/`} class="titlelink">{r.data.title}</a></h3>
          <div class="meta">{r.data.typ} · PAC {r.data.pac ?? "—"} · {r.data.tuk_pct ?? 0} % tuku</div>
          {r.data.description && <p class="desc">{r.data.description}</p>}
        </div>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .about-ranch {
    display: grid;
    grid-template-columns: minmax(180px, 260px) 1fr;
    gap: 1.4rem;
    align-items: center;
    background: var(--card-bg);
    border: 1px solid var(--accent-soft);
    border-radius: 10px;
    padding: 1.3rem;
    margin: 2rem 0;
  }

  .about-ranch-logo {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 220px;
    background: color-mix(in srgb, var(--surface) 62%, transparent);
    border: 1px solid var(--accent-soft);
    border-radius: 8px;
    padding: 1rem;
  }

  .about-ranch-logo img {
    display: block;
    width: min(100%, 240px);
    height: auto;
    filter: drop-shadow(0 10px 18px rgba(61, 46, 30, 0.18));
  }

  .about-ranch h2 {
    margin-top: 0;
  }

  .about-ranch .actions {
    margin-bottom: 0;
  }

  @media (max-width: 700px) {
    .about-ranch {
      grid-template-columns: 1fr;
    }

    .about-ranch-logo {
      min-height: auto;
    }
  }
</style>
